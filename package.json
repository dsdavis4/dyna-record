{
  "name": "dyna-record",
  "version": "0.6.7",
  "description": "Typescript Data Modeler and ORM for Dynamo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.dev.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.dev.json --noEmit",
    "test": "tsc -p tsconfig.dev.json --noEmit && vitest run",
    "test:watch": "vitest",
    "eslint": "npx eslint .",
    "eslint:fix": "npx eslint . --fix",
    "prettier": "npx prettier . --write",
    "docs": "npx typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsdavis4/dyna-record.git"
  },
  "author": "dsdavis4",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dsdavis4/dyna-record/issues"
  },
  "homepage": "https://github.com/dsdavis4/dyna-record#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.502.0",
    "@aws-sdk/lib-dynamodb": "^3.502.0",
    "@aws-sdk/util-dynamodb": "^3.509.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/types": "^3.502.0",
    "@eslint/js": "^9.39.3",
    "@tsconfig/recommended": "^1.0.3",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.2.5",
    "typedoc": "^0.27.6",
    "typedoc-plugin-missing-exports": "^3.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*"
  ]
}
