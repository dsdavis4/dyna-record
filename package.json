{
  "name": "dyna-record",
  "version": "0.7.0",
  "description": "Typescript Data Modeler and ORM for Dynamo",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.dev.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.dev.json --noEmit",
    "test": "tsc -p tsconfig.dev.json --noEmit && vitest run",
    "test:watch": "vitest",
    "eslint": "npx eslint .",
    "eslint:fix": "npx eslint . --fix",
    "prettier": "npx prettier . --write",
    "docs": "npx typedoc",
    "prepublishOnly": "npm run build && npx publint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsdavis4/dyna-record.git"
  },
  "author": "dsdavis4",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dsdavis4/dyna-record/issues"
  },
  "homepage": "https://github.com/dsdavis4/dyna-record#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.502.0",
    "@aws-sdk/lib-dynamodb": "^3.502.0",
    "@aws-sdk/util-dynamodb": "^3.509.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.2.5",
    "publint": "^0.3.21",
    "typedoc": "^0.28.19",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=22.0.0"
  },
  "files": [
    "dist/**/*"
  ]
}
